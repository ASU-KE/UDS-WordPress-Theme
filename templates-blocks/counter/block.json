{
	"name": "acf/uds-counter",
	"title": "UDS Counter",
	"apiVersion": 3,
	"version": "1.0.0",
	"description": "A counter block which has increment animation.",
	"category": "uds",
	"icon": "performance",
	"keywords": ["counter", "number"],
	"acf": {
		"blockVersion": 3,
		"mode": "preview",
		"renderTemplate": "counter.php",
		"validate": false
	},
	"supports": {
		"html": false,
		"align": true,
		"color": {
			"text": true,
			"background": true,
			"gradients": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"viewStyle": "file:./counter.css",
	"viewScript": "file:./counter.js",
	"editorStyle": "file:./counter.css",
	"editorScript": "file:./counter.js",
	"example": {
		"attributes": {
			"mode": "preview",
			"data": {
				"uds_text": "Counter Text",
				"uds_start_digit": 0,
				"uds_end_digit": 100,
				"uds_duration": 2000,
				"uds_steps_between": 10
			}
		}
	}
}
